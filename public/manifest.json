{
	"name": "File Drop",
	"short_name": "FileDrop",
	"start_url": "/",
	"display": "standalone",
	"background_color": "#000000",
	"theme_color": "#007AFF",
	"icons": [
		{
			"src": "https://d11cloud.com/icon-192.png",
			"sizes": "192x192",
			"type": "image/png"
		}
	],
	"share_target": {
		"action": "/upload",
		"method": "POST",
		"enctype": "multipart/form-data",
		"params": {
			"files": [
				{
					"name": "file",
					"accept": ["*/*"]
				}
			]
		}
	}
}
